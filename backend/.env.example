# ============================================
# SISTEMA SALÃO DE BELEZA — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA faça commit do arquivo .env no repositório!

# === Banco de Dados (Neon.tech PostgreSQL) ===
# Obtenha em: https://console.neon.tech → seu projeto → Connection Details
DATABASE_URL="postgresql://usuario:senha@endpoint-pooler.regiao.aws.neon.tech/nome_banco?sslmode=require"
DIRECT_URL="postgresql://usuario:senha@endpoint.regiao.aws.neon.tech/nome_banco?sslmode=require"

# === Autenticação (JWT) ===
# Gere com: openssl rand -base64 64
JWT_SECRET="sua-chave-secreta-jwt-gerada-com-openssl"
JWT_EXPIRES_IN="7d"

# === CORS ===
CORS_ORIGIN="http://localhost:3000"

# === Cloudinary (Upload de Mídia) ===
# Obtenha em: https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME="seu-cloud-name"
CLOUDINARY_API_KEY="sua-api-key"
CLOUDINARY_API_SECRET="seu-api-secret"

# === OAuth2 (Login Social) ===
# Google: https://console.cloud.google.com → Credentials
GOOGLE_CLIENT_ID="seu-google-client-id"
GOOGLE_CLIENT_SECRET="seu-google-client-secret"

# === Servidor ===
PORT=3001
NODE_ENV="development"
