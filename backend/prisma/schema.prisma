// ============================================
// PRISMA SCHEMA — Sistema Salão de Beleza
// ============================================
// Banco de Dados: PostgreSQL (Neon.tech Serverless)
// ORM: Prisma com adapter Neon

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS
// ============================================

enum ComissaoTipo {
  FIXO
  PORCENTAGEM
}

enum AgendamentoStatus {
  CONFIRMADO
  PENDENTE
  EM_ATENDIMENTO
  CONCLUIDO
  CANCELADO
}

enum EstoqueTipo {
  USO_INTERNO
  VENDA
}

enum UserRole {
  ADMIN
  PROFISSIONAL
}

// ============================================
// MODELS
// ============================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  senha        String
  nome         String
  role         UserRole @default(PROFISSIONAL)
  avatarUrl    String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("users")
}

model Cliente {
  id                     String        @id @default(uuid())
  nome                   String
  telefone               String
  email                  String?
  aniversario            DateTime?
  historicoProcedimentos Json?
  fichaAnamnese          String?       @db.Text
  fotoUrl                String?
  criadoEm               DateTime      @default(now())
  atualizadoEm           DateTime      @updatedAt
  agendamentos           Agendamento[]

  @@map("clientes")
}

model Profissional {
  id                 String        @id @default(uuid())
  nome               String
  telefone           String?
  email              String?
  especialidades     String[]
  regraComissaoTipo  ComissaoTipo  @default(PORCENTAGEM)
  regraComissaoValor Decimal       @default(0) @db.Decimal(10, 2)
  ativo              Boolean       @default(true)
  fotoUrl            String?
  criadoEm           DateTime      @default(now())
  atualizadoEm       DateTime      @updatedAt
  agendamentos       Agendamento[]

  @@map("profissionais")
}

model Servico {
  id             String        @id @default(uuid())
  nome           String
  descricao      String?
  preco          Decimal       @db.Decimal(10, 2)
  duracaoMinutos Int
  ativo          Boolean       @default(true)
  criadoEm       DateTime      @default(now())
  atualizadoEm   DateTime      @updatedAt
  agendamentos   Agendamento[]

  @@map("servicos")
}

model Agendamento {
  id             String             @id @default(uuid())
  dataHora       DateTime
  dataHoraFim    DateTime
  status         AgendamentoStatus  @default(PENDENTE)
  notas          String?
  isBloqueio     Boolean            @default(false)
  clienteId      String?
  profissionalId String
  servicoId      String?
  criadoEm       DateTime           @default(now())
  atualizadoEm   DateTime           @updatedAt

  cliente      Cliente?      @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  profissional Profissional  @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  servico      Servico?      @relation(fields: [servicoId], references: [id], onDelete: SetNull)

  @@index([profissionalId, dataHora])
  @@index([clienteId])
  @@index([status])
  @@map("agendamentos")
}

model Estoque {
  id             String      @id @default(uuid())
  nomeProduto    String
  descricao      String?
  tipo           EstoqueTipo
  quantidade     Int         @default(0)
  estoqueMinimo  Int         @default(5)
  precoVenda     Decimal?    @db.Decimal(10, 2)
  precoCusto     Decimal?    @db.Decimal(10, 2)
  fotoProdutoUrl String?
  criadoEm       DateTime    @default(now())
  atualizadoEm   DateTime    @updatedAt

  @@map("estoque")
}

model CaixaFechamento {
  id              String   @id @default(uuid())
  data            DateTime @db.Date
  totalEntradas   Decimal  @db.Decimal(10, 2)
  totalComissoes  Decimal  @db.Decimal(10, 2)
  totalLiquido    Decimal  @db.Decimal(10, 2)
  observacoes     String?
  fechadoPor      String?
  criadoEm        DateTime @default(now())

  @@unique([data])
  @@map("caixa_fechamentos")
}
